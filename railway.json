{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "npm install && cd client && npm install && npm run build && cd .."
  },
  "deploy": {
    "startCommand": "NODE_ENV=production node server/src/index.js",
    "restartPolicyMaxRetries": 5
  }
}
